name: Job Intelligence Cron

on:
  schedule:
    - cron: "0 */4 * * *"  # cada 4 horas (UTC). Ajusta a gusto.
  workflow_dispatch:       # para lanzarlo manualmente desde Actions

jobs:
  run-pipeline:
    runs-on: ubuntu-latest

    env:
      DATABASE_URL: ${{ secrets.DATABASE_URL }}
      SCRAPER_BASE_URL: ${{ secrets.SCRAPER_BASE_URL }}

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run job pipeline
        run: |
          python -m jobs.run_pipeline
